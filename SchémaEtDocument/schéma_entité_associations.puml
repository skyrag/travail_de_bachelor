@startuml
skinparam classAttributeIconSize 0
hide empty members
top to bottom direction

object User {
<u>id</u>
username
oauth_provider
oauth_sub
prénom
nom
email
}

object Participation {
placement
}
Note right
en terme de clé composite la participation aura
l'id de la game et l'id du user
Contrainte :
 - pour une unique partie un user ne peut participer qu'une seule fois
end Note

object Game {
<u>id</u>
date
patch_version
}

object Shop {
<u>version</u>
gold
niveau
entities [0..5]
}

Note right
en terme de clé composite le Shop aura
sa version et la clé de sa team
end Note

object state {
<u>version</u>
winstreak
health
}
Note bottom
en terme de clé composite le state aura
sa version et la clé de sa team
end Note

object team {
<u>version</u>
objects [0..10]
}

Note right
l'équipe a une clé composite qui est constituer
de la clé primaire de Participation et de sa version
Contrainte :
    - une équipe ne stocke que la dernière version de shop
    - une équipe ne stocke que la dernière version de state
    - une équipe ne va stocker au maximum que les 25 unité qui forment l'équipe
end Note

object instanceUnit {
<u>id</u>
isIn
}
Note top
Contrainte :
    - instanceUnit ne stocke que la dernière version de instanceVersion
end NOte


object instanceVersion {
<u>version</u>
objects_id [0..3]
positions
}

object historique {
<u>round</u>
}

Note left
L'historique a pour clé composite les clé étrangères
de game_id, les deux équipes et le round
end Note

Participation "*" --> "1" User : user_id
Participation "8" --> "1" Game : game_id

Shop "1..*" -- "1" team


instanceUnit "0..*" -right- "1" team

historique "1..*" -- "1" Game
historique "1..*" --> "2" team

team "1" -- "1" Participation

team "1" <-- "1..*" state

instanceUnit "1" -- "1..*" instanceVersion


object Unit {
<u>id</u>
patch
name
art
coût
---
health
mana
baseAttack
attackDamage
abilityPower
attackSpeed
armor
magicResist
criticalChance
criticalDamage
range
}

object Ability {
<u>id</u>
name
description
}

object Object {
<u>id</u>
patch
name
description
}

object Effect {
<u>id</u>
type
value
cible
durée
}

object Trait {
<u>id</u>
name
icon
}

object shop_level {
<u>lvl</u>
<u>patch</u>
common_chances
uncommon_chances
rare_chances
epic_chances
legendary_chances
}

object Trait_bonus {
<u>id</u>
threshold
}

Unit "1..*" -- "1..*" Trait
Unit "1" --> "1" Ability

Trait "1" -- "1..*" Trait_bonus

Ability "*" --> "1..*" Effect
Trait_bonus "*" --> "1..*" Effect

Object "*" --> "1..*" Effect





instanceUnit "*" --> "1" Unit


@enduml