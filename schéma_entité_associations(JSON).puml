@startuml
skinparam classAttributeIconSize 0
hide empty members
top to bottom direction

object User {
<u>id</u>
username
oauth_provider
oauth_sub
prénom
nom
email
}

object Participation {
placement
}

object Game {
<u>id</u>
date
patch_version
}

object Changement {
<u>id</u>
eventType
event_version
paylod (JSON)
created_at
seq_number
}

Note top
Changement a pour clé composite la clé étrangère
de Participation(game_id et user_id) et id
end Note


object Snapshot {
<u>id</u>
state (JSON)
created_at
last_changement_seq
}

Note left
Snapshot a pour clé composite la clé étrangère
de Participation(game_id et user_id) et id
end Note


Participation "*" --> "1" User : user_id
Participation "8" --> "1" Game : game_id

Changement "1..*" --> "1" Participation

Snapshot "1..*" --> "1" Participation





